// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// npx prisma migrate dev --name add_token_version

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"] // 🚀 OBAVEZNO ZA PRISMA 7 LOCAL DB
}

datasource db {
  provider = "postgresql"
  
 
}
 


model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  tokenVersion Int      @default(0) // <--- DODAJTE OVO
}

model Apartment {
  id       String    @id @default(cuid())
  name     String    @unique 
  description String? @db.Text
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?

  rates     ApartmentRate[] 
  bookings Booking[]
  reservationRequests  ReservationRequest[]        

   @@index([isDeleted])
}

model ApartmentRate {
  id          String    @id @default(cuid())
  apartmentId String
  apartment   Apartment @relation(fields: [apartmentId], references: [id])
  
  startDate   DateTime  // When this seasonal rate starts (inclusive)
  endDate     DateTime  // When this seasonal rate ends (inclusive)
  price       Decimal   @db.Decimal(10, 2) // Nightly rate for this window

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([apartmentId, startDate, endDate])
}

model Booking {
  id          String        @id @default(cuid())
  apartmentId String
  guest       String
  email       String
  phone       String?
  startDate   DateTime
  endDate     DateTime
  status      BookingStatus @default(CONFIRMED)
  totalPrice  Decimal  @db.Decimal(10, 2)

  createdAt   DateTime      @default(now())
  apartment   Apartment     @relation(fields: [apartmentId], references: [id])
  updatedAt   DateTime      @updatedAt  // DODATI
  @@index([apartmentId])               // DODATI za performanse
  @@index([apartmentId, startDate, endDate])  // Za kalendar pretragu
  @@index([createdAt(sort: Desc)])
}

model ReservationRequest {
  id          String        @id @default(cuid())
  apartmentId String
  guest       String
  email       String
  phone       String?
  startDate   DateTime
  endDate     DateTime
  status      RequestStatus @default(PENDING_EMAIL)     
  emailToken  String?       @unique         
  expiresAt   DateTime      
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt  
  apartment   Apartment     @relation(fields: [apartmentId], references: [id])

  @@index([status, expiresAt])
  @@map("reservation_requests")
}

enum Role {
  ADMIN
  VIEWER
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  
}

enum RequestStatus {
  PENDING_EMAIL
  PENDING_APPROVAL
  APPROVED
  REJECTED
  EXPIRED
}
